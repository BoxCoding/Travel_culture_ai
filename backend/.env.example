GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash

# Shared secret used to verify short-lived bridge JWTs issued by the Next.js/Auth.js frontend
AUTH_BRIDGE_SECRET=change-me-shared-with-frontend

# Full JSON contents of a Firebase Admin service account key (Firestore access)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","...":"..."}

CORS_ORIGINS=http://localhost:3000
