# Auth.js session secret (generate with `openssl rand -base64 32`)
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Canonical URL of this Next.js app
NEXTAUTH_URL=http://localhost:3000

# Shared HS256 secret used to mint/verify the auth-bridge JWT.
# MUST be the exact same value as AUTH_BRIDGE_SECRET in backend/.env
AUTH_BRIDGE_SECRET=replace-with-shared-secret-matching-backend

# Base URL of the FastAPI backend
BACKEND_API_URL=http://localhost:8000

# Full JSON contents of a Firebase Admin service account key -- same Firebase project
# (and can be the same key) as backend/.env's FIREBASE_SERVICE_ACCOUNT_JSON. Used to store
# user accounts in a `users` Firestore collection (doc id = lowercased email).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","...":"..."}
